# Public URL (no trailing slash). OxaPay return_url + callback_url use this.
# Render: set to your live URL, e.g. https://extinsionupdate.onrender.com
# If unset or localhost on Render, RENDER_EXTERNAL_URL is used automatically.
APP_PUBLIC_URL=https://extinsionupdate.onrender.com

PORT=3000

# License server (Update Fee API)
LICENSE_SERVER_BASE=https://marketqxtrade.pythonanywhere.com
UPDATE_FEE_API_TOKEN=UF-your-token-here

# Optional: override project_type try order (comma or |). Default matches license server doc exactly:
# Quotex, Quotex Low Quality — no aliases.
# UPDATE_FEE_PROJECT_TYPES=Quotex|Quotex Low Quality

# Optional: log each /pending attempt (HTTP status + code) on the server console.
# UPDATE_FEE_DEBUG=1

# OxaPay — never expose these in the browser
OXAPAY_MERCHANT_API_KEY=your-merchant-api-key

# Optional: server polls unpaid orders so license can activate if the user closes the tab (default poll every 35s, max order age 2h).
# PENDING_PAYMENT_POLL_MS=35000
# PENDING_PAYMENT_MAX_ORDER_AGE_MS=7200000

# Optional: comma-separated IPs to trust for webhook (empty = skip IP check)
# OXAPAY_WEBHOOK_ALLOWED_IPS=
